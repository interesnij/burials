<% include!("../header.stpl"); %>

    <section class="property-five" style="margin-top:100px;height: 100vh;">
        <div class="container">
        <h4 style="text-decoration: underline" href="/create_organization/">Предложенные фирмы</h4>
          <div class="row"> 
            <% for i in users_list.iter() { %>
                <div style="margin-bottom:10px">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <img src="<%= i.get_image() %>" class="h-11 w-11 shadow" alt="img">
                            <div class="ms-3 flex-1">
                                <a><%= i.username %></a>
                                
                                <p class="small"> 
                                    <% if i.is_admin() { %>
                                        <a class="pointer remove_staff text-slate-400 hover:text-indigo-600 duration-500 ms-5" data-pk="<%= i.id %>">
                                            Убрать из админов
                                        </a>
                                    <% } else { %>
                                        <a class="pointer create_admin text-slate-400 hover:text-indigo-600 duration-500 ms-5" data-pk="<%= i.id %>">
                                            Сделать админом
                                        </a>
                                    <% } %>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
          </div>
        </div>
    </section>

<% include!("../footer.stpl"); %>