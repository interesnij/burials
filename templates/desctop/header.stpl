                        <li class="has-submenu parent-menu-item">
                            <a href="javascript:void(0)" class="admin">Админ</a><span class="menu-arrow"></span>

                            <ul class="submenu">
                                <% if services_enabled { %>
                                    <li><a href="/create_service/" class="sub-menu-item create_service">Добавить услугу</a></li>
                                <% } %>
                                <li><a href="/create_country/" class="sub-menu-item create_country">Добавить страну</a></li>
                                <li><a href="/create_region/" class="sub-menu-item create_region">Добавить регион</a></li>
                                <li><a href="/create_district/" class="sub-menu-item create_district">Добавить район</a></li>
                                <li><a href="/create_city/" class="sub-menu-item create_city">Добавить город</a></li>
                                <li><a href="/create_organization/" class="sub-menu-item create_organization">Добавить организацию</a></li>
