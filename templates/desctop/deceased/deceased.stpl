                    <div class="container md:mt-24 mt-16">
                        <div class="grid grid-cols-1 pb-8 text-center">
                            <h3 class="mb-6 md:text-3xl text-2xl md:leading-normal leading-normal font-semibold">Организации работающие в вашем городе</h3>
        
                            <p class="text-slate-400 max-w-xl mx-auto">Найдите организацию или услугу действующую в вашем районе</p>
                        </div><!--end grid-->
        
                        <div class="grid grid-cols-1 lg:grid-cols-3 md:grid-cols-2 mt-8 gap-[30px]">
                            <div class="blog relative rounded-md shadow dark:shadow-gray-800 overflow-hidden">

                                <img src="/static/images/service/service1.jpg" alt="">
        
                                <div class="content p-6">
                                    <a href="/organization/{id}/services/" class="title h5 text-lg font-medium hover:text-indigo-600 duration-500 ease-in-out">
                                    
                                    Памятники/Надгробия
                                    
                                    </a>
                                    <p class="text-slate-400 mt-3"> 
                                    
                                    создание и установка монументов, сохраняющих память о ушедших и служащих в качестве места для вечной памяти
                                    
                                    </p>
                                    
                                    <div class="mt-4">
                                        <a 
                                        
                                        href="/organization/{id}/services/" 
                                        
                                        class="btn btn-link font-normal hover:text-indigo-600 after:bg-indigo-600 duration-500 ease-in-out">Подробнее <i class="uil uil-arrow-right"></i></a>
                                    </div>
                                </div>
                            </div>
                        </div><!--end grid-->
                    </div><!--end container-->
                </section><!--end section-->
